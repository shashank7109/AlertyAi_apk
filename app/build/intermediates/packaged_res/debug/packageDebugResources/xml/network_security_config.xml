<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) only for local development backend -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>    <!-- Android emulator → host machine -->
        <domain includeSubdomains="false">10.0.3.2</domain>    <!-- Genymotion emulator → host machine -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
    </domain-config>
    <!-- All other traffic must use HTTPS (production safety) -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
